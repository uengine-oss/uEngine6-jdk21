# Keycloak installed mode for Red Hat VM / external WAS deployments.
# Keycloak latest checked on 2026-05-11: 26.6.1

# Keycloak server bootstrap values. These are used by Keycloak itself only
# when the master realm does not exist yet.
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change-me
KC_HOSTNAME=https://keycloak.example.com
KC_PROXY_HEADERS=xforwarded
KC_HTTP_ENABLED=true
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://db.example.com:5432/keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=change-me

# Gateway
SPRING_PROFILES_ACTIVE=keycloak-installed
GATEWAY_PORT=8088
GATEWAY_URI=https://bpm.example.com
FRONTEND_URI=http://localhost:5173
PROCESS_SERVICE_URI=http://localhost:9094
DEFINITION_SERVICE_URI=http://localhost:9093
EXECUTION_SERVICE_URI=http://localhost:8000

# Keycloak OIDC client used by keycloak-gateway and process-gpt-vue3-hli.
KEYCLOAK_URI=https://keycloak.example.com
KEYCLOAK_REALM=uengine
KEYCLOAK_CLIENT_ID=uengine
KEYCLOAK_CLIENT_SECRET=change-me

# Keycloak Admin API credentials used by process-service role lookups.
KEYCLOAK_ADMIN_REALM=master
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
